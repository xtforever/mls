		(							
		(* define what files those bash functions generate *)	
		rules: (						
			sbison: '.y .c .h'				
			sflex: '.l .c .h'				
			ccompile: '.c .o'				
			)						
files: 'bf.c mls.c '
nodes: (
(
OUT: ('bitfield')
IN:  ('bf.o' 'mls.o' )
DEP: ('icon.png')
REC:  slink
)
(
OUT: ('icon.png')
IN:  ('icon.svg' )
REC:  svg2png
)


))
